{
	"name": "cryptosense-monorepo",
	"private": true,
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "yarn@4.14.1",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*",
		"services/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
